---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Dra. Graciela Ghetti | Jubilación Docente y Derecho Previsional",
  description = "Estudio jurídico especializado en jubilación docente, derecho previsional y civil en Argentina. Más de 20 años de experiencia en el ámbito educativo.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <slot />
  </body>
</html>
