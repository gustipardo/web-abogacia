---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

interface AlternateLanguage {
  lang: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  noindex?: boolean;
  alternateLanguages?: AlternateLanguage[];
}

const {
  title = "Dra. Adriana Ghetti — Jubilación Docente y Multas | Estudio Ghetti",
  description = "Estudio jurídico argentino especializado en jubilación docente (IPS, Ley 24.016) y multas de tránsito. Más de 20 años de experiencia educativa. Consulta sin cargo.",
  ogType = 'website',
  ogImage = '/og-default.png',
  noindex = false,
  alternateLanguages = [],
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://www.estudioghetti.com');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
---

<!DOCTYPE html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="theme-color" content="#1B2A4A" />

    <link rel="canonical" href={canonicalUrl} />
    {alternateLanguages.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={alt.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Estudio Ghetti" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <Analytics />

    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Saltar al contenido</a>
    <slot />
  </body>
</html>
