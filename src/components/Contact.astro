---
---

<section class="section contact" id="contacto">
  <div class="container contact-grid">

    <div class="contact-info">
      <p class="section-label">Contacto</p>
      <h2 class="section-title">Hablemos de su caso</h2>
      <p class="contact-desc">
        La primera consulta es sin costo. Cuénteme su situación y le explico qué opciones tiene, sin compromiso.
      </p>

      <div class="contact-channels">
        <a href="https://wa.me/5491169380777?text=Hola%20Dra.%20Ghetti%2C%20quer%C3%ADa%20hacerle%20una%20consulta."
           class="channel" target="_blank" rel="noopener">
          <div class="channel-icon channel-icon--green">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.554 4.12 1.527 5.855L.057 23.5l5.83-1.527A11.938 11.938 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.003-1.373l-.36-.214-3.724.977.994-3.63-.235-.373A9.818 9.818 0 1112 21.818z"/>
            </svg>
          </div>
          <div>
            <strong>WhatsApp</strong>
            <span>+54 9 11 6938-0777</span>
            <small>Respondo en el día</small>
          </div>
          <svg class="channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <a href="mailto:adriana@estudioghetti.com" class="channel">
          <div class="channel-icon channel-icon--navy">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
          </div>
          <div>
            <strong>Email</strong>
            <span>adriana@estudioghetti.com</span>
            <small>Para consultas formales</small>
          </div>
          <svg class="channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <div class="channel channel--no-link">
          <div class="channel-icon channel-icon--gold">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <strong>Zona de atención</strong>
            <span>Pilar, Buenos Aires</span>
            <small>Consultas también por videollamada</small>
          </div>
        </div>
      </div>
    </div>

    <div class="contact-form-wrap">
      <form id="contact-form" class="contact-form" novalidate>
        <h3 class="form-title">Envíe su consulta</h3>
        <p class="form-subtitle">Le respondo en menos de 24 horas hábiles. <span class="required-note">Los campos con * son obligatorios.</span></p>

        <div class="form-row">
          <label class="field">
            <span>Nombre completo *</span>
            <input type="text" name="nombre" placeholder="Ej: María González" required />
          </label>
          <label class="field">
            <span>Teléfono <em class="field-optional">(opcional)</em></span>
            <div class="phone-group">
              <span class="phone-prefix" aria-label="Código de país Argentina">+54</span>
              <input class="phone-input phone-area" type="tel" name="telefono_area" placeholder="11" maxlength="4" inputmode="tel" autocomplete="tel-area-code" aria-label="Código de área" />
              <input class="phone-input phone-num" type="tel" name="telefono_num" placeholder="6938-0777" maxlength="12" inputmode="tel" autocomplete="tel-local" aria-label="Número de teléfono" />
            </div>
          </label>
        </div>

        <label class="field">
          <span>Email *</span>
          <input type="email" name="email" placeholder="su@email.com" required />
        </label>

        <label class="field">
          <span>Área de consulta <em class="field-optional">(opcional)</em></span>
          <select name="area">
            <option value="">Seleccione una opción...</option>
            <option value="jubilacion-docente">Jubilación Docente</option>
            <option value="previsional">Derecho Previsional</option>
            <option value="reajuste">Reajuste de haberes</option>
            <option value="pension">Pensión por fallecimiento</option>
            <option value="civil">Derecho Civil</option>
            <option value="multas">Multas de tránsito</option>
            <option value="otro">Otro</option>
          </select>
        </label>

        <label class="field">
          <span>Su consulta *</span>
          <textarea name="mensaje" rows="5" placeholder="Cuénteme su situación brevemente..." required></textarea>
        </label>

        <div id="form-error" class="form-error" hidden role="alert"></div>

        <button id="form-submit" type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
          Enviar consulta →
        </button>

        <p class="form-note">
          Sus datos son confidenciales y se utilizan únicamente para responder su consulta.
        </p>
      </form>

      <div id="form-success" class="form-success" hidden>
        <div class="success-check" aria-hidden="true">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <h3>Mensaje enviado</h3>
        <p>Recibimos tu consulta. Te respondemos a tu email en menos de 24 horas hábiles.</p>
        <button id="form-reset" type="button" class="btn btn-navy success-reset-btn">Enviar otra consulta</button>
      </div>
    </div>

  </div>
</section>

<style>
  .contact {
    background: var(--bg);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-desc {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .contact-channels {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .channel {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    transition: box-shadow 0.2s, transform 0.2s;
    text-decoration: none;
    color: var(--text);
  }

  a.channel:hover {
    box-shadow: var(--shadow);
    transform: translateY(-1px);
  }

  .channel > div:not(.channel-icon) {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .channel strong {
    font-size: 0.9rem;
    color: var(--navy);
  }

  .channel span {
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  .channel small {
    font-size: 0.75rem;
    color: var(--text-muted);
    opacity: 0.75;
  }

  .channel-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--white);
  }

  .channel-icon--green { background: #25D366; }
  .channel-icon--navy { background: var(--navy); }
  .channel-icon--gold { background: var(--gold); }

  .channel-arrow {
    color: var(--text-muted);
    opacity: 0.4;
    flex-shrink: 0;
  }

  /* Form */
  .contact-form-wrap {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.25rem;
    box-shadow: var(--shadow);
  }

  .form-title {
    font-size: 1.3rem;
    color: var(--navy);
    margin-bottom: 0.25rem;
  }

  .form-subtitle {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field span {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--navy);
  }

  .field-optional {
    font-style: normal;
    font-weight: 400;
    color: var(--text-muted);
    font-size: 0.92em;
    margin-left: 0.15rem;
  }

  .field-hint {
    font-size: 0.74rem;
    color: var(--text-muted);
    opacity: 0.8;
    margin-top: 0.15rem;
  }

  .required-note {
    font-style: italic;
    opacity: 0.85;
  }

  .field input,
  .field select,
  .field textarea {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    border: 1.5px solid var(--border);
    border-radius: 7px;
    padding: 0.7rem 0.9rem;
    color: var(--text);
    background: var(--bg);
    transition: border-color 0.15s;
    resize: vertical;
    outline: none;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--navy);
    background: var(--white);
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: #b0aab8;
  }

  /* Phone subfields */
  .phone-group {
    display: flex;
    align-items: stretch;
    border: 1.5px solid var(--border);
    border-radius: 7px;
    background: var(--bg);
    overflow: hidden;
    transition: border-color 0.15s, background 0.15s;
  }

  .phone-group:focus-within {
    border-color: var(--navy);
    background: var(--white);
  }

  .phone-prefix {
    padding: 0.7rem 0.75rem;
    font-size: 0.92rem;
    color: var(--text-muted);
    font-weight: 600;
    border-right: 1px solid var(--border);
    display: flex;
    align-items: center;
    flex-shrink: 0;
    background: rgba(0,0,0,0.02);
  }

  .phone-input {
    border: none;
    background: transparent;
    padding: 0.7rem 0.75rem;
    font-size: 0.92rem;
    color: var(--text);
    font-family: var(--font-sans);
    outline: none;
    min-width: 0;
  }

  .phone-area {
    width: 70px;
    border-right: 1px solid var(--border);
    text-align: center;
  }

  .phone-num {
    flex: 1;
  }

  .phone-input::placeholder {
    color: #b0aab8;
  }

  /* Inline error */
  .form-error {
    background: #FEEFEF;
    border: 1px solid #F5C2C2;
    color: #B33939;
    border-radius: 7px;
    padding: 0.75rem 0.9rem;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .form-note {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: center;
    opacity: 0.8;
  }

  /* Respetar el atributo hidden incluso con display: flex */
  .contact-form[hidden],
  .form-success[hidden] {
    display: none;
  }

  /* Success state */
  .form-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.85rem;
    padding: 1rem 0.5rem 0.5rem;
    animation: successFadeIn 0.45s ease-out;
  }

  .success-check {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: #E8F5E9;
    color: #2E7D32;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.4rem;
    animation: successScaleIn 0.5s 0.1s ease-out backwards;
  }

  .form-success h3 {
    font-size: 1.45rem;
    color: var(--navy);
    font-family: var(--font-serif);
  }

  .form-success > p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 340px;
  }

  .success-reset-btn {
    margin-top: 0.75rem;
  }

  .form-submit-loading {
    opacity: 0.7;
    cursor: wait;
  }

  @keyframes successFadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes successScaleIn {
    0% { transform: scale(0); }
    70% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // La key se lee desde la variable de entorno PUBLIC_WEB3FORMS_KEY
  // (definida en .env localmente, y en el panel del host en producción).
  // Si no está seteada, el formulario muestra un error explicativo en lugar de enviar.
  const WEB3FORMS_ACCESS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success') as HTMLDivElement | null;
  const errorBox = document.getElementById('form-error') as HTMLDivElement | null;
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement | null;
  const resetBtn = document.getElementById('form-reset') as HTMLButtonElement | null;

  const areaLabels: Record<string, string> = {
    'jubilacion-docente': 'Jubilación Docente',
    'previsional': 'Derecho Previsional',
    'reajuste': 'Reajuste de haberes',
    'pension': 'Pensión por fallecimiento',
    'civil': 'Derecho Civil',
    'multas': 'Multas de tránsito',
    'otro': 'Otro',
  };

  function showError(msg: string) {
    if (!errorBox) return;
    errorBox.textContent = msg;
    errorBox.hidden = false;
  }

  if (form && success && errorBox && submitBtn && resetBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox.hidden = true;

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      if (!WEB3FORMS_ACCESS_KEY) {
        showError('El formulario todavía no está conectado al servicio de email. Mientras tanto, podés escribirnos a adriana@estudioghetti.com o por WhatsApp.');
        return;
      }

      const data = new FormData(form);
      const nombre = String(data.get('nombre') ?? '').trim();
      const email = String(data.get('email') ?? '').trim();
      const telArea = String(data.get('telefono_area') ?? '').trim();
      const telNum = String(data.get('telefono_num') ?? '').trim();
      const tel = (telArea || telNum) ? `+54 ${telArea} ${telNum}`.replace(/\s+/g, ' ').trim() : '';
      const areaConsulta = String(data.get('area') ?? '').trim();
      const mensaje = String(data.get('mensaje') ?? '').trim();

      const payload = new FormData();
      payload.append('access_key', WEB3FORMS_ACCESS_KEY);
      payload.append('subject', `Consulta web — ${nombre}`);
      payload.append('from_name', 'Web Estudio Ghetti');
      payload.append('Nombre', nombre);
      payload.append('Email', email);
      if (tel) payload.append('Teléfono', tel);
      if (areaConsulta && areaLabels[areaConsulta]) {
        payload.append('Área de consulta', areaLabels[areaConsulta]);
      }
      payload.append('Mensaje', mensaje);

      submitBtn.disabled = true;
      submitBtn.classList.add('form-submit-loading');
      const originalLabel = submitBtn.textContent;
      submitBtn.textContent = 'Enviando…';

      try {
        const resp = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: payload,
        });
        const result = await resp.json();
        if (!resp.ok || !result.success) {
          throw new Error(result.message || 'Error desconocido');
        }
        form.hidden = true;
        success.hidden = false;
      } catch (err) {
        showError('No pudimos enviar el mensaje. Probá de nuevo en un momento o escribinos directamente a adriana@estudioghetti.com.');
        submitBtn.disabled = false;
        submitBtn.classList.remove('form-submit-loading');
        submitBtn.textContent = originalLabel;
      }
    });

    resetBtn.addEventListener('click', () => {
      form.reset();
      submitBtn.disabled = false;
      submitBtn.classList.remove('form-submit-loading');
      submitBtn.textContent = 'Enviar consulta →';
      errorBox.hidden = true;
      success.hidden = true;
      form.hidden = false;
    });
  }
</script>
