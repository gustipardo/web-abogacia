---

<section class="section contact" id="contacto">
  <div class="container contact-grid">

    <div class="contact-info">
      <p class="section-label">Contacto</p>
      <h2 class="section-title">Hablemos de su caso</h2>
      <p class="contact-desc">
        La primera consulta es sin costo. Cuénteme su situación y le explico qué opciones tiene, sin compromiso.
      </p>

      <div class="contact-channels">
        <a href="https://wa.me/5491100000000?text=Hola%20Dra.%20Ghetti%2C%20quiero%20consultar%20sobre%20mi%20jubilaci%C3%B3n%20docente."
           class="channel" target="_blank" rel="noopener">
          <div class="channel-icon channel-icon--green">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.554 4.12 1.527 5.855L.057 23.5l5.83-1.527A11.938 11.938 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.003-1.373l-.36-.214-3.724.977.994-3.63-.235-.373A9.818 9.818 0 1112 21.818z"/>
            </svg>
          </div>
          <div>
            <strong>WhatsApp</strong>
            <span>+54 9 11 0000-0000</span>
            <small>Respondo en el día</small>
          </div>
          <svg class="channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <a href="mailto:dra.ghetti@ejemplo.com" class="channel">
          <div class="channel-icon channel-icon--navy">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
          </div>
          <div>
            <strong>Email</strong>
            <span>dra.ghetti@ejemplo.com</span>
            <small>Para consultas formales</small>
          </div>
          <svg class="channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <div class="channel channel--no-link">
          <div class="channel-icon channel-icon--gold">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <strong>Zona de atención</strong>
            <span>Buenos Aires, Argentina</span>
            <small>Consultas también por videollamada</small>
          </div>
        </div>
      </div>
    </div>

    <div class="contact-form-wrap">
      <form class="contact-form" name="contacto" method="POST" data-netlify="true" novalidate>
        <h3 class="form-title">Envíe su consulta</h3>
        <p class="form-subtitle">Le respondo en menos de 24 horas hábiles.</p>

        <div class="form-row">
          <label class="field">
            <span>Nombre completo *</span>
            <input type="text" name="nombre" placeholder="Ej: María González" required />
          </label>
          <label class="field">
            <span>Teléfono</span>
            <input type="tel" name="telefono" placeholder="+54 9 11 ..." />
          </label>
        </div>

        <label class="field">
          <span>Email *</span>
          <input type="email" name="email" placeholder="su@email.com" required />
        </label>

        <label class="field">
          <span>Área de consulta</span>
          <select name="area">
            <option value="">Seleccione una opción...</option>
            <option value="jubilacion-docente">Jubilación Docente</option>
            <option value="previsional">Derecho Previsional</option>
            <option value="reajuste">Reajuste de haberes</option>
            <option value="pension">Pensión por fallecimiento</option>
            <option value="civil">Derecho Civil</option>
            <option value="otro">Otro</option>
          </select>
        </label>

        <label class="field">
          <span>Su consulta *</span>
          <textarea name="mensaje" rows="5" placeholder="Cuénteme su situación brevemente..." required></textarea>
        </label>

        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
          Enviar consulta →
        </button>

        <p class="form-note">
          Sus datos son confidenciales y se utilizan únicamente para responder su consulta.
        </p>
      </form>
    </div>

  </div>
</section>

<style>
  .contact {
    background: var(--bg);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-desc {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .contact-channels {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .channel {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    transition: box-shadow 0.2s, transform 0.2s;
    text-decoration: none;
    color: var(--text);
  }

  a.channel:hover {
    box-shadow: var(--shadow);
    transform: translateY(-1px);
  }

  .channel > div:not(.channel-icon) {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .channel strong {
    font-size: 0.9rem;
    color: var(--navy);
  }

  .channel span {
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  .channel small {
    font-size: 0.75rem;
    color: var(--text-muted);
    opacity: 0.75;
  }

  .channel-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--white);
  }

  .channel-icon--green { background: #25D366; }
  .channel-icon--navy { background: var(--navy); }
  .channel-icon--gold { background: var(--gold); }

  .channel-arrow {
    color: var(--text-muted);
    opacity: 0.4;
    flex-shrink: 0;
  }

  /* Form */
  .contact-form-wrap {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.25rem;
    box-shadow: var(--shadow);
  }

  .form-title {
    font-size: 1.3rem;
    color: var(--navy);
    margin-bottom: 0.25rem;
  }

  .form-subtitle {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field span {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--navy);
  }

  .field input,
  .field select,
  .field textarea {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    border: 1.5px solid var(--border);
    border-radius: 7px;
    padding: 0.7rem 0.9rem;
    color: var(--text);
    background: var(--bg);
    transition: border-color 0.15s;
    resize: vertical;
    outline: none;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--navy);
    background: var(--white);
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: #b0aab8;
  }

  .form-note {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: center;
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
