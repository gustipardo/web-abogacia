# Web3Forms access key — la usa el formulario de contacto para enviar consultas por email.
# Obtenela registrándote en https://web3forms.com con adriana@estudioghetti.com.
# Tiene que tener el prefijo PUBLIC_ para que Astro la inyecte en el bundle del cliente.
PUBLIC_WEB3FORMS_KEY=

# Umami self-hosted analytics. Si están vacías, no se carga el script.
# Setup completo: ver Context/umami-setup.md
PUBLIC_UMAMI_URL=
PUBLIC_UMAMI_WEBSITE_ID=

# Resend — usado por /api/submit-ficha para enviar la ficha de consulta previsional
# a la Dra. por email. Crear API key en https://resend.com (registrada con
# adriana@estudioghetti.com). Dominio estudioghetti.com debe estar verificado en Resend.
RESEND_API_KEY=
# Email destino (a quién llega la ficha). Default: adriana@estudioghetti.com
FICHA_TO_EMAIL=
# Remitente. Debe ser de un dominio verificado en Resend.
FICHA_FROM_EMAIL=Estudio Ghetti <noreply@estudioghetti.com>
